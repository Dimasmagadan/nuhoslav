# Database (matches docker-compose defaults — no change needed)
DATABASE_URL=postgresql+asyncpg://odor:odor@db:5432/odor
DATABASE_URL_SYNC=postgresql+psycopg2://odor:odor@db:5432/odor

# Your apartment coordinates
USER_LAT=44.7
USER_LON=37.8

# Port bounding box geofence (draw on maps.google.com, copy lat/lon corners)
PORT_LAT_MIN=44.72
PORT_LAT_MAX=44.76
PORT_LON_MIN=37.76
PORT_LON_MAX=37.82

# Alert thresholds
VESSEL_DOCKED_HOURS=2.0          # how long a tanker must be docked to qualify
WIND_ANGLE_TOLERANCE_DEG=45.0    # ±degrees from port→apartment bearing
WIND_SPEED_MIN_MS=1.5            # minimum wind speed to carry smell
ALERT_PAUSE_MINUTES=10           # pause after alert before resuming checks
ALERT_TIMEOUT_HOURS=1.0          # max time in alerted state (then reset to normal)
CHECK_INTERVAL_MINUTES=30        # how often to run the regular check cycle

# AISstream.io — free account at https://aisstream.io
AISSTREAM_API_KEY=your_key_here

# Telegram — create bot via @BotFather, get your chat ID via @userinfobot
# TELEGRAM_CHAT_ID accepts multiple comma-separated IDs for multiple recipients
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_CHAT_ID=123456789,987654321
